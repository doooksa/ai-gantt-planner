# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# --- LLM provider (OpenAI-compatible) ---
# The backend uses the OpenAI SDK against any OpenAI-compatible endpoint. Three
# knobs select the provider:
#   LLM_BASE_URL     — the API base URL
#   LLM_API_KEY_ENV  — the NAME of the env var holding the key
#   LLM_MODEL        — the model id
#
# Default profile: OpenRouter + Haiku 4.5. On the 10-command agent gate Haiku
# scored 10/10 (5/5 stable), matching Sonnet 4.5's correctness at ~1.5x lower
# latency/cost — correctness comes from the tools/validation layer, not the model.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY_ENV=OPENROUTER_API_KEY
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4.5
#
# Alternative profile — Google AI Studio (OpenAI-compatible). gemini-2.5-flash is
# fast (~2-8s/command) and calls tools well, but the FREE tier is capped at
# ~5 req/min AND ~20 req/day per model — one agent command makes several requests,
# so free tier allows only a handful of edits/day (not viable for real use). Use a
# paid Google tier for production. To switch:
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_API_KEY_ENV=GOOGLE_API_KEY
#   GOOGLE_API_KEY=<your-google-ai-studio-key>
#   LLM_MODEL=gemini-2.5-flash

# CORS: origin of the frontend app.
FRONTEND_ORIGIN=http://localhost:5173

# Storage (backend).
DATABASE_URL=sqlite:///./gantt.db
