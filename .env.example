# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).

# OpenRouter (LLM) — used from Phase 2 onward.
OPENROUTER_API_KEY=
# Default: Haiku 4.5. On the 10-command agent gate it scored 10/10 (5/5 stable
# runs), matching Sonnet 4.5's correctness at ~1.5x lower latency/cost — because
# the tools/validation layer, not the model, guarantees correctness. Upgrade to
# a stronger model by changing just this one variable, e.g.:
#   LLM_MODEL=anthropic/claude-sonnet-4.5
LLM_MODEL=anthropic/claude-haiku-4.5

# CORS: origin of the frontend app.
FRONTEND_ORIGIN=http://localhost:5173

# Storage (backend).
DATABASE_URL=sqlite:///./gantt.db
